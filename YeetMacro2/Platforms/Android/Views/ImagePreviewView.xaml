<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pvm="clr-namespace:YeetMacro2.Platforms.Android.ViewModels"
             xmlns:vm="clr-namespace:YeetMacro2.ViewModels"
             x:DataType="pvm:ImagePreviewViewModel"
             vm:ViewModelLocator.ViewModelType="{x:Type pvm:ImagePreviewViewModel}"
             x:Class="YeetMacro2.Platforms.Android.Views.ImagePreviewView"
             BackgroundColor="{AppThemeBinding Light={StaticResource Background}, Dark={StaticResource BackgroundDark}}"
             Padding="10">
    <Grid RowDefinitions="Auto,*">
        <Label Grid.Row="0" Text="{Binding ImageInfo}" FontSize="12" />
        <Image Grid.Row="1" Source="{Binding ImageSource}" Aspect="AspectFit" />
    </Grid>
</ContentView>
